---
import Layout from '../../../layouts/Layout.astro';
import AppShell from '../../../components/AppShell.astro';

interface Exercise {
  name: string;
  tier: 1 | 2;
  notes?: string[];
}

interface MuscleGroup {
  name: string;
  id: string;
  gradient: string;
  accentColor: string;
  exercises: Exercise[];
}

const muscleGroups: MuscleGroup[] = [
  {
    name: "Glute Minimus",
    id: "minimus",
    gradient: "from-rose-500/20 to-orange-500/20",
    accentColor: "rose",
    exercises: [
      { name: "Side Plank Leg Lift", tier: 1, notes: ["5 reps, 10s hold each"] },
      { name: "Loaded Single Leg RDL", tier: 1 },
      { name: "Loaded Hip Hike", tier: 2, notes: ["Weight high enough that 12-15 reps are hard"] },
    ]
  },
  {
    name: "Glute Medius",
    id: "medius",
    gradient: "from-violet-500/20 to-fuchsia-500/20",
    accentColor: "violet",
    exercises: [
      { name: "Side Plank Leg Lift", tier: 1, notes: ["5 reps, 10s hold each"] },
      { name: "Loaded Single Leg Squat", tier: 1, notes: ["Variations: touchdown squat, shrimp squat"] },
      { name: "Loaded Single Leg RDL", tier: 1 },
      { name: "Lateral Band Walk", tier: 2, notes: ["Band on the feet to increase tension", "Good for coordination and stability, not for strength building"] },
    ]
  },
  {
    name: "Glute Max",
    id: "max",
    gradient: "from-sky-500/20 to-cyan-500/20",
    accentColor: "sky",
    exercises: [
      { name: "Loaded Single-Leg Hip Thrust", tier: 1, notes: ["Weight high enough that 12-15 reps are hard"] },
      { name: "Loaded Split Squat", tier: 1 },
      { name: "Loaded Single Leg RDL", tier: 1 },
    ]
  }
];

// Find exercises that appear in multiple muscle groups
const exerciseCounts = new Map<string, string[]>();
muscleGroups.forEach(group => {
  group.exercises.forEach(ex => {
    const current = exerciseCounts.get(ex.name) || [];
    current.push(group.name);
    exerciseCounts.set(ex.name, current);
  });
});

const multiTargetExercises = Array.from(exerciseCounts.entries())
  .filter(([_, groups]) => groups.length > 1)
  .sort((a, b) => b[1].length - a[1].length);
---

<Layout
  title="Glute Muscles - Fitness - Gabriele Angeletti"
  description="Targeted exercises for glute minimus, medius, and maximus strength and stability."
>
  <AppShell>
    <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-0 w-[600px] h-[600px] bg-rose-500/5 rounded-full blur-[120px]"></div>
      <div class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-violet-500/5 rounded-full blur-[100px]"></div>
      <div class="absolute bottom-0 left-1/3 w-[700px] h-[400px] bg-sky-500/5 rounded-full blur-[150px]"></div>
    </div>

    <div class="relative z-10 p-4 lg:py-18">
      <div class="max-w-4xl mx-auto">
        <div class="breadcrumbs text-sm mb-8">
          <ul>
            <li><a href="/fitness" class="text-primary hover:underline">Fitness</a></li>
            <li><a href="/fitness#training" class="text-primary hover:underline">Training</a></li>
            <li>Glute Muscles</li>
          </ul>
        </div>

        <header class="mb-12">
          <h1 class="text-4xl md:text-5xl font-black tracking-tight text-base-content mb-4">
            Glute Muscles
          </h1>
          <p class="text-lg text-base-content/60 max-w-2xl">
            Targeted exercises for the three gluteal muscles. Lower tier numbers indicate higher effectiveness.
          </p>
        </header>

        <!-- Tier Legend -->
        <div class="flex flex-wrap items-center gap-6 mb-12 p-4 rounded-xl bg-base-100/50 border border-base-content/5 backdrop-blur-sm">
          <span class="text-sm font-medium text-base-content/60">Tier Legend:</span>
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500/20 text-emerald-600 text-xs font-bold ring-1 ring-emerald-500/30">1</span>
            <span class="text-sm text-base-content/80">Most effective</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-500/20 text-amber-600 text-xs font-bold ring-1 ring-amber-500/30">2</span>
            <span class="text-sm text-base-content/80">Effective</span>
          </div>
        </div>

        <!-- Multi-target Exercises Callout -->
        {multiTargetExercises.length > 0 && (
          <section class="mb-16">
            <div class="relative overflow-hidden rounded-2xl border border-base-content/5 bg-gradient-to-br from-base-100/80 to-base-100/40 backdrop-blur-xl">
              <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/5 via-transparent to-emerald-500/5"></div>
              <div class="relative p-6 md:p-8">
                <div class="flex items-start gap-4 mb-6">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-xl font-bold text-base-content mb-1">Multi-Target Exercises</h2>
                    <p class="text-sm text-base-content/60">These exercises work multiple gluteal muscles simultaneously.</p>
                  </div>
                </div>
                <div class="grid gap-3">
                  {multiTargetExercises.map(([name, groups]) => (
                    <div class="flex flex-wrap items-center gap-3 p-3 rounded-lg bg-base-100/60 border border-base-content/5">
                      <span class="font-medium text-base-content">{name}</span>
                      <span class="text-base-content/30">targets</span>
                      <div class="flex flex-wrap gap-2">
                        {groups.map((group, i) => (
                          <span class:list={[
                            "text-xs font-medium px-2 py-1 rounded-full",
                            group === "Glute Minimus" && "bg-rose-500/10 text-rose-600",
                            group === "Glute Medius" && "bg-violet-500/10 text-violet-600",
                            group === "Glute Max" && "bg-sky-500/10 text-sky-600",
                          ]}>
                            {group.replace("Glute ", "")}
                          </span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </section>
        )}

        <!-- Muscle Group Sections -->
        <div class="space-y-16">
          {muscleGroups.map((group, groupIndex) => (
            <section id={group.id} class="relative">
              <!-- Decorative line connecting sections -->
              {groupIndex < muscleGroups.length - 1 && (
                <div class="absolute left-8 top-full w-px h-16 bg-gradient-to-b from-base-content/10 to-transparent hidden md:block"></div>
              )}
              
              <div class="relative">
                <!-- Section header -->
                <div class="flex items-center gap-4 mb-8">
                  <div class:list={[
                    "w-16 h-16 rounded-2xl flex items-center justify-center text-2xl font-black",
                    group.accentColor === "rose" && "bg-rose-500/10 text-rose-500",
                    group.accentColor === "violet" && "bg-violet-500/10 text-violet-500",
                    group.accentColor === "sky" && "bg-sky-500/10 text-sky-500",
                  ]}>
                    {group.name.split(" ")[1].charAt(0)}
                  </div>
                  <div>
                    <h2 class="text-2xl font-bold text-base-content">{group.name}</h2>
                    <p class="text-sm text-base-content/50">{group.exercises.length} exercises</p>
                  </div>
                </div>

                <!-- Exercises grid -->
                <div class="grid gap-4">
                  {group.exercises
                    .sort((a, b) => a.tier - b.tier)
                    .map((exercise, i) => (
                    <div class:list={[
                      "group relative overflow-hidden rounded-xl border transition-all duration-300",
                      "hover:shadow-lg hover:-translate-y-0.5",
                      exercise.tier === 1 
                        ? "bg-gradient-to-r from-base-100 to-base-100/80 border-base-content/10 hover:border-base-content/20" 
                        : "bg-base-100/60 border-base-content/5 hover:border-base-content/10",
                    ]}>
                      <!-- Subtle gradient overlay for tier 1 -->
                      {exercise.tier === 1 && (
                        <div class:list={[
                          "absolute inset-0 opacity-30 group-hover:opacity-50 transition-opacity",
                          `bg-gradient-to-r ${group.gradient}`,
                        ]}></div>
                      )}
                      
                      <div class="relative p-5">
                        <div class="flex items-start gap-4">
                          <!-- Tier badge -->
                          <span class:list={[
                            "flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold transition-transform group-hover:scale-110",
                            exercise.tier === 1 
                              ? "bg-emerald-500/20 text-emerald-600 ring-1 ring-emerald-500/30" 
                              : "bg-amber-500/20 text-amber-600 ring-1 ring-amber-500/30",
                          ]}>
                            {exercise.tier}
                          </span>
                          
                          <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-3 mb-2">
                              <h3 class="text-lg font-semibold text-base-content">{exercise.name}</h3>
                              
                              {/* Show multi-target indicator */}
                              {(exerciseCounts.get(exercise.name)?.length ?? 0) > 1 && (
                                <span class="text-xs text-base-content/40 flex items-center gap-1">
                                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                  </svg>
                                  Multi-target
                                </span>
                              )}
                            </div>
                            
                            {exercise.notes && exercise.notes.length > 0 && (
                              <ul class="space-y-1">
                                {exercise.notes.map((note) => (
                                  <li class="text-sm text-base-content/60 flex items-start gap-2">
                                    <span class="text-base-content/30 mt-1">-</span>
                                    <span>{note}</span>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </section>
          ))}
        </div>

        <div class="mt-16 text-center">
          <a href="/fitness" class="btn btn-outline">
            ← Back to Fitness
          </a>
        </div>
      </div>
    </div>
  </AppShell>
</Layout>
